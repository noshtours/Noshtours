{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {"source": "/", "destination": "/index.html"},
    {"source": "/destinations", "destination": "/destinations.html"},
    {"source": "/experience", "destination": "/experience.html"},
    {"source": "/india", "destination": "/india.html"},
    {"source": "/about", "destination": "/about.html"},
    {"source": "/blog", "destination": "/blog-listing.html"},
    {"source": "/wellness", "destination": "/wellness.html"},
    {"source": "/international", "destination": "/international.html"},
    {"source": "/blog/kerala-ayurveda-retreat-uk-travellers-2026", "destination": "/kerala-ayurveda-retreat-uk-travellers-2026.html"},
    {"source": "/blog/what-is-unscripted-travel-india", "destination": "/what-is-unscripted-travel-india.html"},
    {"source": "/blog/gift-luxury-trip-india-2026", "destination": "/gift-luxury-trip-india-2026.html"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "X-Frame-Options", "value": "SAMEORIGIN"},
        {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"},
        {"key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains"},
        {"key": "Permissions-Policy", "value": "geolocation=(), camera=(), microphone=()"}
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=3600, must-revalidate"}]
    },
    {
      "source": "/images/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
    },
    {
      "source": "/logo.png",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {"key": "Content-Type", "value": "text/plain; charset=utf-8"},
        {"key": "Cache-Control", "value": "public, max-age=86400"}
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        {"key": "Content-Type", "value": "text/plain; charset=utf-8"},
        {"key": "Cache-Control", "value": "public, max-age=86400"}
      ]
    }
  ]
}
