{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/blog", "destination": "/blog-listing" },
    { "source": "/blog/kerala-ayurveda-retreat-uk-travellers-2026", "destination": "/kerala-ayurveda-retreat-uk-travellers-2026" },
    { "source": "/blog/what-is-unscripted-travel-india", "destination": "/what-is-unscripted-travel-india" },
    { "source": "/blog/gift-luxury-trip-india-2026", "destination": "/gift-luxury-trip-india-2026" }
  ],
  "redirects": [
    { "source": "/blog-listing", "destination": "/blog", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    },
    {
      "source": "/(.*).(jpg|jpeg|png|webp|gif|svg|woff|woff2|css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
